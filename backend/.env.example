DATABASE_URL=postgresql://user:password@localhost:5432/study_jam
JWT_SECRET=supersecretkey
FRONTEND_URL=http://localhost:5173
# Cloud Run frontend URL example:
# FRONTEND_URL=https://frontend-305659654950.africa-south1.run.app
OAUTH_STATE_SECRET=generate-a-secure-random-32-byte-secret-here

# Optional granular settings (used when DATABASE_URL is not provided)
DB_NAME=study_jam
DB_USER=backend_app
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_INSTANCE_CONNECTION_NAME=project-id:africa-south1:backend-sql
DB_SOCKET_PATH=/cloudsql
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:4173

# OAuth providers - for local development only
# For Cloud Run production, store these in Secret Manager:
# - GOOGLE_CLIENT_ID -> backend-google-client-id
# - GOOGLE_CLIENT_SECRET -> backend-google-client-secret
# - GITHUB_CLIENT_ID -> backend-github-client-id
# - GITHUB_CLIENT_SECRET -> backend-github-client-secret
# - OAUTH_STATE_SECRET -> backend-oauth-state-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local callback
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Cloud Run callback (set via env var in production)
# GOOGLE_CALLBACK_URL=https://backend-305659654950.africa-south1.run.app/auth/google/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
# Cloud Run callback (set via env var in production)
# GITHUB_CALLBACK_URL=https://backend-305659654950.africa-south1.run.app/auth/github/callback
